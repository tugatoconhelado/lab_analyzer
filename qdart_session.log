     pset('amp', data[peaks[0]], min=0)\n\n        pset('cen', time_array[peaks[0]], min=0)\n\n        pset('wid', widths[0], min=0)\n\n        background = np.min(data[data > 0])\n        pset('background', background, min=0)\n        #print(f'Guessed background = {background}')\n\n        return lmfit.models.update_param_vals(params, self.prefix, **kwargs)"), (107, 8, '%matplotlib inline\n\ndef analyse_irf(irf_path, window, ax = None, save_path=None, title=None, debug=False):\n\n    with h5py.File(irf_path, \'r\') as data:\n        counts = np.array(data[\'Data\'][\'histogram\'][:])\n        time_bins = np.array(data[\'Data\'][\'time_bins\'][:])\n\n    counts = counts[(time_bins >= window[0]) & (time_bins <= window[1])]\n    time_bins = time_bins[(time_bins >= window[0]) & (time_bins <= window[1])]\n\n    counts = counts / np.max(counts)\n\n    model = GaussianModel()\n    params = model.guess(counts, time_bins)\n    result = model.fit(counts, params, t=time_bins)\n\n    if ax is None:\n        fig, ax = plt.subplots(figsize=(6, 4))\n\n    ax.plot(time_bins, counts, \'bo\', label=\'Data\', markersize=4)\n    ax.plot(time_bins, result.best_fit, \'r-\', label=r\'Gaussian fit\')\n\n    #ax.set_xlabel(\'Time (ns)\')\n    #ax.set_ylabel(\'Counts\')\n    #ax.legend()\n\n    ax.spines[\'bottom\'].set_bounds(min(time_bins), max(time_bins))\n    ax.spines[\'left\'].set_bounds(min(counts), max(counts))\n\n    ax.xaxis.set_major_locator(ticker.MaxNLocator(5))\n    ax.xaxis.set_minor_locator(ticker.AutoMinorLocator(2))\n    #ax.yaxis.set_major_locator(ticker.MaxNLocator(3))\n    #ax.yaxis.set_minor_locator(ticker.AutoMinorLocator(2))\n    ax.spines[\'bottom\'].set_position((\'outward\', 5))\n    \n    report_str = f\'IRF Center = {result.best_values["cen"]:.2f} ns | FWHM = {result.best_values["wid"]:.3f} ns\'\n    if title is not None:\n        report_str = title + \' \' + report_str\n    print(report_str)\n    std_results = {\n        \'cen_std\': result.params[\'cen\'].stderr,\n        \'wid_std\': result.params[\'wid\'].stderr,\n        \'amp_std\': result.params[\'amp\'].stderr,\n        \'b_str\': result.params[\'background\'].stderr\n    }\n    std_results.update(result.best_values)\n\n    if debug:\n        print(result.fit_report())\n    if title is not None:\n        ax.set_title(title)\n    if save_path is not None:\n        fig.savefig(save_path, dpi=300, transparent=True, bbox_inches=\'tight\')\n    return std_results'), (107, 9, "data_dir = os.path.join('data', '20241205irfpowerdata')\nwindow = (0.3, 1.3)\ni = 10\nrow = 0\ncolumn = 0\nfig, ax = plt.subplots(5, 2, figsize=(15.58 * cm_to_in, 20* cm_to_in), layout='constrained', sharex=True, sharey=True)\nfor file in sorted(os.listdir(data_dir))[:-1]:\n    data_path = os.path.join(data_dir, file)\n    data = h5py.File(data_path, 'r')\n    \n    counts = np.array(data['Data']['histogram'][:])\n    time_bins = np.array(data['Data']['time_bins'][:])\n\n    counts = counts[(time_bins > window[0]) & (time_bins < window[1])]\n    time_bins = time_bins[(time_bins > window[0]) & (time_bins < window[1])]\n    analyse_irf(data_path, window, ax=ax[row][column], title=f'Power = {i} V')\n    if column == 0:\n        ax[row][column].set_ylabel('Counts')\n        ax[row][column].set_yticks([0, 0.5, 1], minor=False)\n        ax[row][column].set_yticks([0.25, 0.75], minor=True)\n\n    i -= 1\n    row += 1\n    if row == 5:\n        row = 0\n        column += 1\n\nax[4][0].xaxis.set_major_locator(ticker.MaxNLocator(5))\nax[4][0].xaxis.set_minor_locator(ticker.AutoMinorLocator(2))\nax[4][1].xaxis.set_major_locator(ticker.MaxNLocator(5))\nax[4][1].xaxis.set_minor_locator(ticker.AutoMinorLocator(2))\nax[4][0].set_xlabel('Time (ns)')\nax[4][1].set_xlabel('Time (ns)')\n\nfig.savefig(os.path.join('figures', 'masters_thesis', 'full_irf_fits.png'), dpi=600, transparent=True, bbox_inches='tight')"), (107, 10, "data_dir = os.path.join('data', '20241205irfpowerdata')\ni = 10\nirf_fit_results = []\nfor fil