et_bounds(min(time_array), max(time_array))\n    ax.spines['left'].set_bounds(min(counts_array), max(counts_array))\n    if legend:\n        ax.legend(frameon=False)\n\n    ax.xaxis.set_major_locator(ticker.MaxNLocator(5))\n    ax.xaxis.set_minor_locator(ticker.AutoMinorLocator(2))\n    ax.yaxis.set_major_locator(ticker.MaxNLocator(3))\n    ax.yaxis.set_minor_locator(ticker.AutoMinorLocator(2))\n\n    if save_path is not None:\n        fig.savefig(save_path, dpi=300, transparent=True, bbox_inches='tight')"), (107, 36, "class DoubleExponentialLifetimeModel(lmfit.Model):\n\n    def __init__(self, *args, **kwargs):\n        super().__init__(self.double_exponential, *args, **kwargs)\n    \n\n    @staticmethod\n    def double_exponential(t, irf, norm, tau1, tau2, t0, r):\n        exp1 = r * np.exp(- (t - t0) / tau1) * np.heaviside(t - t0, 1)\n        exp2 = (1 - r) * np.exp(- (t - t0) / tau2) * np.heaviside(t - t0, 1)\n        #decay = I0 * (exp1 + exp2)\n        decay = (exp1 + exp2)\n        decay_convolved = np.convolve(irf, decay, mode='full')[:len(t)]\n        decay_convolved = decay_convolved / max(decay_convolved)\n        return decay_convolved * norm / np.sum(decay_convolved) #+ dark_counts\n    \n    def guess(self, data, time_array, irf, **kwargs):\n\n        self.total_counts = np.sum(data)\n        params = self.make_params()\n        def pset(param, value, **kwargs):\n            params[param].set(value=value, **kwargs)\n\n        pset('tau1', 0.1, min=0)\n        pset('tau2', 0.1, min=0)\n        pset('t0', min(time_array), min=min(time_array), max=max(time_array))\n        pset('r', 0.5, min=0, max=1)\n        #pset('dark_counts', 0, min=0)\n\n        background = np.average(data)\n        #print(f'Guessed background = {background}')\n        #pset('background', 10, min=0)\n\n        #print(f'Max irf = {np.max(irf)}')\n        I0 = 1 / np.max(np.convolve(data, irf, mode='full')[:len(time_array)])\n        #print(f'Guessed I0 = {I0}')\n\n        #pset('t0', 0.5, min=min(time_array), max=max(time_array))\n        #pset('I0', I0, min=0)\n        #pset('I2', 0.5, min=0)\n\n        return lmfit.models.update_param_vals(params, self.prefix, **kwargs)"), (107, 37, "%matplotlib inline\ndef irf_gaussian(t, amp, cen, wid, background):\n    gaussian = amp * np.exp(- 1 / 2 * ((t - cen) / (wid / (2 * np.sqrt(2 * np.log(2))))) ** 2)\n    return gaussian + background\n\ndef exponential(t, tau, r, t0):\n    return r * np.exp(-(t -t0) / tau)\n\ndef analyse_lifetime_data(data_filepath, irf_filepath, window, save_name=None, ax=None, legend=False):\n\n\n    with h5py.File(irf_filepath, 'r') as f:\n        irf = np.array(f['Data']['histogram'][:])\n        irf_time = np.array(f['Data']['time_bins'][:])\n\n    with h5py.File(data_filepath, 'r') as f:\n        time_array = np.array(f['Data']['time_bins'][:])\n        counts_array = np.array(f['Data']['histogram'][:])\n\n    counts = counts_array[(time_array > window[0]) & (time_array < window[1])]\n    time_array = time_array[(time_array > window[0]) & (time_array < window[1])]\n    irf = irf[(irf_time > window[0]) & (irf_time < window[1])]\n\n    counts = counts #/ np.max(counts)\n    counts = [ct if ct > 0 else 1 for ct in counts]\n    counts = np.array(counts)\n    counts = counts #/ np.max(counts)\n    irf = [ir if ir > 0 else 1 for ir in irf]\n    irf = np.array(irf)\n    irf_original = irf\n    irf_fit = irf_gaussian(time_array, amp=683.154971, cen=0.71419385, wid=0.08015513, background=0.0)\n    #irf = irf_fit #/ np.max(irf)\n\n    model = DoubleExponentialLifetimeModel(independent_vars=['t', 'irf', 'norm'])\n    params = model.guess(counts, time_array=time_array, irf=irf)\n    #initial_guess = model.double_exponential(time_array, **params, irf=irf)\n\n    neyman_weight = np.array([max(counts[i], 1) for i in range(len(counts))])\n    #neyman_weight = np.ones(len(counts))\n\n    fit = model.fit(counts, params, t=time_array, irf=irf, norm=np.sum(counts), method='leastsq', scale_covar=True, weights=1 / np.sqrt(neyman_weight))\n\n    chisq = np.sum(((fit.best_fit - counts) ** 2 / neyman_weight))\n    #print(f'Minimum counts {min(counts[counts>0])}')\n    #print(f'Total number of counts: {np.sum(counts)}')\n    #print('Total number of fitted counts: {}'.format(np.sum(fit.best_fit)))\n    #print('chi squared: {}'.format(chisq))\n    #print('reduced chi squared: {}'.format(chisq / (len(time_array) - len(fit.params) - 1)))\n    #print('length of data: {}'.format(len(counts)))\n\n\n    #initial_prediction = model.exponential(time_array, *(0.0025, 0.6, 2.96), irf=irf)\n    initial_prediction = None\n    #print(fit.fit_report())\n    #plot_lifetime_fit(time_array, counts, fit.best_fit, irf, initial_prediction, tau, model, save_path='lifetime_fit.png')\n\n    y1 = exponential(time_array, fit.params['tau1'].value, fit.params['r'].value, fit.params['t0'].value) * max(counts)\n    y2 = exponential(time_array, fit.params['tau2'].value, 1 - fit.params['r'].value, fit.params['t0'].value) * max(counts)\n\n    if ax is None:\n        fig, ax = plt.subplots(figsize=(3.11 * 2 * 2, 3.11 * 2))\n    ax.plot(time_array, counts, 'o', label='Data', color='blue', markersize=3)\n    ax.plot(time_array, fit.best_fit, '-', label='Fit', color='red')\n    #ax.plot(time_array, y1, '-', label='Exp 1', color='red')\n    #ax.plot(time_array, y2, '-', label='Exp 2', color='red')\n    ax.plot(time_array, irf_original / max(irf_original) * max(counts), '-', color='green', label='IRF')\n    #ax.plot(time_array, irf_fit / max(irf_fit) * max(counts), '-', label='IRF Gaussian fit', color='green')\n    #ax.plot(time_array, initial_guess, '-', color='purple', label='Initial guess')\n    \n    #ax.set_xlabel('Time (ns)')\n    ax.set_ylabel('Intensity (a.u.)')\n    ax.grid(False)\n    if legend is True:\n        ax.legend(frameon=False)\n    \n    # Range frames\n    ax.spines['bottom'].set_bounds(min(time_array), max(time_array))\n    ax.spines['left'].set_bounds(min(counts), max(counts))\