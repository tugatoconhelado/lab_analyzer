widths = widths * (time_array[1] - time_array[0])\n        #print(time_array[peaks])\n        #print(data[peaks])\n        #print(widths)\n\n        pset(\'amp1\', 70, min=0)\n        pset(\'amp2\', 8, min=0)\n\n        pset(\'cen1\', 876, min=0)\n        pset(\'cen2\', 860, min=0)\n\n        pset(\'wid1\', 40, min=0)\n        pset(\'wid2\', 20, min=0)\n\n        background = np.min(data[data > 0])\n        print(f\'Guessed background = {background}\')\n        pset(\'background\', 13, min=0)\n\n\n        return lmfit.models.update_param_vals(params, self.prefix, **kwargs)\n    \ndef analyse_spectrum(spect_path, window=(700, 1000), ax=None, save_path=None):\n\n    with h5py.File(spect_path, \'r\') as f:\n        wavelength = np.array(f[\'Data\'][\'wavelength\'][:])\n        spectrum = np.array(f[\'Data\'][\'average\'][:])\n\n    spectrum = spectrum[(wavelength > window[0]) & (wavelength < window[1])]\n    wavelength = wavelength[(wavelength > window[0]) & (wavelength < window[1])]\n\n    model = DoubleGaussianModel()\n    params = model.guess(spectrum, wavelength)\n    result = model.fit(spectrum, params, t=wavelength)\n\n    print(f\'Peak 1: {result.params["cen1"].value} +- {result.params["cen1"].stderr} nm\')\n    print(f\'Peak 2: {result.params["cen2"].value} +- {result.params["cen2"].stderr} nm\')\n\n    if ax is None:\n        fig, ax = plt.subplots(figsize=(7, 5))\n        fig.tight_layout()\n\n    ax.plot(wavelength, spectrum, label=\'Data\')\n    ax.plot(wavelength, result.best_fit, \'-\', label=r\'Double gaussian fit\')\n    gauss1 = gaussian(wavelength, result.params[\'amp1\'].value, result.params[\'cen1\'].value, result.params[\'wid1\'].value, result.params[\'background\'].value)\n    gauss2 = gaussian(wavelength, result.params[\'amp2\'].value, result.params[\'cen2\'].value, result.params[\'wid2\'].value, result.params[\'background\'].value)\n    #ax.plot(wavelength, gauss1, \'--\', label=\'Gaussian 1\', alpha=0.8)\n    #ax.plot(wavelength, gauss2, \'--\'