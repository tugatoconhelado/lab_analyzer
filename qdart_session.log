, **kwargs):\n            params[param].set(value=value, **kwargs)\n\n        pset('d', 1, min=0, max=1)\n        pset('phi', 0.1, min=0, max=np.pi / 2)\n        #pset('alpha', 0.1, min=0, max=2 * np.pi)\n        pset('theta_0', 1, min=0, max=2 * np.pi)\n\n\n        return lmfit.models.update_param_vals(params, self.prefix, **kwargs)"), (107, 16, 'def analyse_polarization(pol_file, save_path=None, ax=None):\n\n    with h5py.File(pol_file, \'r\') as f:\n        pol_data = f[\'Data\']\n        angle_data = pol_data[\'angle\'][:]\n        pol_data = pol_data[\'fluorescence\'][:]\n\n    pol_data = pol_data / np.max(pol_data)\n    angle_data = np.deg2rad(angle_data)\n\n    model = PolarizationModel()\n    params = model.guess(angle_data, pol_data)\n    result = model.fit(pol_data, params, theta=angle_data)\n\n    if ax is None:\n        fig, ax = plt.subplots(subplot_kw={\'projection\': \'polar\'})\n        fig.tight_layout()\n\n    \n    ax.plot(angle_data, pol_data, color=\'b\')\n    ax.plot(angle_data, result.best_fit, \'-\', color=\'r\')\n    \n    ax.tick_params(axis=\'y\', colors=\'white\')\n    ax.set_title(f\'$\\phi = {np.rad2deg(result.best_values["phi"]):.2f}°$\')\n    #ax.set_yticks(np.linspace(0, 1, 5))\n    \n    ax.grid(True)\n    #fig.legend(frameon=False, loc=\'upper right\')\n    #print(result.fit_report())\n    print(f\'Phi = {np.rad2deg(result.params["phi"].value)} +- {np.rad2deg(result.params["phi"].stderr)} deg\')\n    #print(f\'Alpha = {np.rad2deg(result.params["alpha"].value)} +- {np.rad2deg(result.params["alpha"].stderr)} deg\')\n    print(f\'Theta_0 = {np.rad2deg(result.params["theta_0"].value)} +- {np.rad2deg(result.params["theta_0"].stderr)} deg\')\n\n    if save_path is not None:\n        fig.savefig(save_path, dpi=600, bbox_inches=\'tight\', transparent=True)'), (107, 17, "spot1_pol_file = os.path.join('data', 'sochifi2024nico', 'polarization', '20241031-1328-38_PLZ.h5')\nspot2_pol_file = os.path.join('data', 'sochifi2024nico', 'polarization'