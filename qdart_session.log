r_size_str} $\\mu m$\',\n        loc=\'upper right\',\n        pad=1,\n        color=\'white\',\n        frameon=False,\n        size_vertical=float(pixels[0] / 140)\n    )\n    ax.add_artist(scalebar)\n    ax.spines[\'bottom\'].set_visible(False)\n    ax.spines[\'left\'].set_visible(False)\n\n    if save_path != \'\':\n        fig.savefig(save_path, dpi=600, transparent=True)\n    elif save_path == \'\':\n        fig.show()\n    return fig'), (131, 8, "img_path = os.path.join('data', 'Nov_2025', 'Diffraction Limited 1', '20250925-1312-23_IMG.h5')\nwith h5py.File(img_path, 'r') as f:\n    image = f['Data']\n    x_data = image['x'][:]\n    y_data = image['y'][:]\n    img_data = image['counter_image_bw'][:]\n\nconfocal_image_plot(img_data, x_data, y_data, save_path=os.path.join('figures', 'quostxi', 'confocal_image.png'))\n\n1 + 1"), (131, 9, 'def spectrum_plot(\n        x_data : np.ndarray, intensity : np.ndarray, window: tuple,\n        save_path : str = \'\') -> matplotlib.figure.Figure:\n    """\n    Creates a plot of `x_data` versus `intensity`.\n\n    Sets labels based on unit (TO BE IMPLEMENTED). Modifies the number of major\n    and minor ticks. Creates range frames to the max an min values of x and y\n    axis.\n\n    Parameters\n    ----------\n    x_data : np.ndarray\n        Array containing the data to be displayed on the x axis\n    intensity : np.ndarray\n        Array containing the data of the intensity of the spectrum, it is\n        displyed on the y axis.\n    units : str\n        Units for the x axis\n    save_path : str\n        Path to save the image\n    Returns\n    -------\n    fig : matplotlib.figure.Figure\n        Figure containing the plot.\n    """\n    x = x_data\n    y = intensity\n    y = y[(x > window[0]) & (x < window[1])]\n    x = x[(x > window[0]) & (x < window[1])]\n    \n    fig, ax = plt.subplots(figsize=(11.7, 7))\n    fig.tight_layout()\n\n    ax.plot(x, y, color=\'#21024E\')\n\n    ax.set_xlabel(\'Wavelength (nm)\')\n    ax.