e the derivatives at each time step\nderivatives = np.array([system(t, y) for t, y in zip(solution.t, solution.y.T)])\n\n# Plot the derivatives\nplt.plot(solution.t, derivatives[:, 0], label="dp_g/dt")\nplt.plot(solution.t, derivatives[:, 1], label="dp_e/dt")\nplt.plot(solution.t, derivatives[:, 2], label="dp_m/dt")\nplt.plot(solution.t, derivatives[:, 0]+derivatives[:, 1]+derivatives[:, 2], label="Sum")\nplt.xlabel("Time (ns)")\nplt.ylabel("Derivatives")\nplt.title("Derivatives Solution to the ODE System")\nplt.legend()\nplt.grid(True)\nplt.show()'), (111, 4, '1 / np.e'), (111, 5, "%matplotlib inline\n#Ecuaciones diferenciales\n# En GHz:\n\ndef solve_three_level_system_rate_eq(ks: tuple = (1, 1, 1, 1), t_eval: np.ndarray = np.array([]), mod_func=None):\n\n    k_ge_on   = ks[0] * 1e6 # g->e\n    k_eg      = ks[1] * 1e6 # e->g\n    k_em      = ks[2] * 1e6 # e->s\n    k_mg      = ks[3] * 1e6 # s->g\n\n    if mod_func is None:\n        mod_func = lambda t: 1\n    # Define the system with the rates\n    def system(t, y):\n        k_ge = mod_func(t * 1e6) * k_ge_on\n        p_g, p_e, p_m = y\n        dp_gdt = - k_ge * p_g + k_eg * p_e + k_mg * p_m\n        dp_edt = k_ge * p_g - (k_eg + k_em) * p_e\n        dp_mdt = k_em * p_e - k_mg * p_m\n\n        return [dp_gdt, dp_edt, dp_mdt]\n\n    # Initial conditions\n    p0 = [1, 0, 0]\n\n    # Time units in us\n    t_eval = t_eval * 1e-6\n    # Time span\n    t0 = np.min(t_eval)\n    t1 = np.max(t_eval)\n\n    # Solve the system\n    solution = solve_ivp(system, [t0, t1], p0, t_eval=t_eval, method='RK45')\n    t_sol = solution.t * 1e6\n\n    return t_sol, solution.y"), (111, 6, "%matplotlib inline\n# Time units in us\nN = 100000 # Number of points\nlaser_on_time = 1\nlaser_off_time = 0.2\nperiod = laser_on_time + laser_off_time\nt_end = period * 2.07\n\ndef laser_signal(t):\n    t = np.asarray(t)\n    result = np.where((t % period) < laser_off_time, 0, 1)\n    if result.size == 1:\n        return result.item()\n    return result\n\n# Rates in MHz\nk_ge = 833.33  # g->e\nk_eg = 833.33  # e->g\nk_em = 10   # e->s\nk_mg = 7.6 # s->g\nks_nv = (k_ge, k_eg, k_em, k_mg)\n\nt_array = np.linspace(0, t_end, N)\nlaser_sig = laser_signal(t_array)\n\nt_sol, solution = solve_three_level_system_rate_eq(ks_nv, t_eval=t_array, mod_func=laser_signal)\n\nfig, ax = plt.subplots()\n\n#plt.plot(t_array, laser_sig, label='Laser Signal', color='grey', linestyle='--')\n#plt.plot(t_sol, solution[0], label=r'$\\rho_g(t)$', color='green')\nax.plot(t_sol, solution[1], label=r'$\\rho_e(t)$', color='blue')\nax.plot(t_sol, solution[2], label=r'$\\rho_m(t)$', color='red')\n#plt.plot(t_sol, solution[0] + solution[1] + solution[2], label='Sum', linestyle=':', color='purple')\nax.set_xlabel('Time (us)')\nax.set_ylabel('Density')\nax.legend(loc='upper right')\n\n# Set number of minor and major ticks\nax.xaxis.set_major_locator(ticker.MaxNLocator(5))\nax.xaxis.set_minor_locator(ticker.AutoMinorLocator(2))\nax.yaxis.set_major_locator(ticker.MaxNLocator(3))\nax.yaxis.set_minor_locator(ticker.AutoMinorLocator(2))\n\nax.spines['top'].set_visible(False)\nax.spines['right'].set_visible(False)\nax.spines['bottom'].set_bounds(min(t_sol), max(t_sol))\nax.spines['left'].set_bounds(min(solution[1]), max(solution[1]))\n\nplt.show()"), (111, 7, 'def get_p_e_for_different_laser_params(ks, t_end, N, laser_on_time, laser_off_time):\n    t_array = np.linspace(0, t_end, N)\n    period = laser_on_time + laser_off_time\n\n    def laser_signal(t):\n        t = np.asarray(t)\n        result = np.where((t % period) < laser_on_time, 1, 0)\n        if result.size == 1:\n            return result.item()\n        return result\n\n    t_sol, solution = solve_three_level_system_rate_eq(ks, t_eval=t_array, mod_func=laser_signal)\n\n    return t_sol, solution  # Return the time array and the population of the excited state'), (111, 8, 'def get_rel_peak(t_array, solution):\n    \n    #baseline = solution[1][(t_array > 0.8) & (t_array < 0.8 + 0.1)].mean()\n 