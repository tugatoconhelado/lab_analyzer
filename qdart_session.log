ian_function + background\n\nclass DoubleGaussianModel(lmfit.Model):\n\n    def __init__(self, *args, **kwargs):\n        super().__init__(self.double_gaussian, *args, **kwargs)\n\n    @staticmethod\n    def double_gaussian(t, amp1, amp2, cen1, cen2, wid1, wid2, background):\n\n        gaussian1 = gaussian(t, amp1, cen1, wid1, background / 2)\n        gaussian2 = gaussian(t, amp2, cen2, wid2, background / 2)\n        return gaussian1 + gaussian2\n    \n    def guess(self, data, time_array, **kwargs):\n\n        params = self.make_params()\n        def pset(param, value, **kwargs):\n            params[param].set(value=value, **kwargs)\n\n        peaks= sp.signal.find_peaks(data, height=max(data) - 20, distance=5, width=3)[0]\n        widths, widht_heights, left_ips, right_ips = sp.signal.peak_widths(data, peaks, rel_height=0.5)\n        widths = widths * (time_array[1] - time_array[0])\n        print(time_array[peaks])\n        print(data[peaks])\n        print(widths)\n\n        pset(\'amp1\', 20, min=0)\n        pset(\'amp2\', 20, min=0)\n\n        pset(\'cen1\', time_array[peaks[0]], min=0)\n        pset(\'cen2\', time_array[peaks[1]], min=0)\n\n        pset(\'wid1\', 20, min=0)\n        pset(\'wid2\', 20, min=0)\n\n        background = np.min(data[data > 0])\n        print(f\'Guessed background = {background}\')\n        pset(\'background\', background, min=0)\n\n\n        return lmfit.models.update_param_vals(params, self.prefix, **kwargs)\n    \ndef analyse_spectrum(spect_path, window=(700, 1000), ax=None, save_path=None):\n\n    with h5py.File(spect_path, \'r\') as f:\n        wavelength = np.array(f[\'Data\'][\'wavelength\'][:])\n        spectrum = np.array(f[\'Data\'][\'average\'][:])\n\n    spectrum = spectrum[(wavelength > window[0]) & (wavelength < window[1])]\n    wavelength = wavelength[(wavelength > window[0]) & (wavelength < window[1])]\n\n    model = DoubleGaussianModel()\n    params = model.guess(spectrum, wavelength)\n    result = model.fit(spectru